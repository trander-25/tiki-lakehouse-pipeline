# --- Data Lake (MinIO) ---
# S3-compatible object storage for raw and transformed data
MINIO_ENDPOINT=http://localhost:9000           # API endpoint
MINIO_ROOT_USER=admin                          # Root username
MINIO_ROOT_PASSWORD=password                   # Root password (use strong password in prod)
MINIO_ACCESS_KEY=admin                         # Access key (can differ from root)
MINIO_SECRET_KEY=password                      # Secret key (use strong password in prod)

# --- Metastore & Backend (Postgres) ---
# PostgreSQL database for Airflow metadata + Superset backend
POSTGRES_USER=admin                            # Postgres superuser
POSTGRES_PASSWORD=password                     # Postgres password (use strong password in prod)
POSTGRES_DB=metastore                          # Default database name
POSTGRES_HOST=postgres                         # Docker service name (or localhost if running outside Docker)
POSTGRES_PORT=5432                             # Postgres port

# --- Visualization (Superset) ---
# Apache Superset for interactive dashboards and data exploration
SUPERSET_SECRET_KEY=super_secret_lakehouse_key # Secret key for Superset (change in production!)
SUPERSET_ADMIN_USER=admin                      # Admin username
SUPERSET_ADMIN_PASSWORD=password               # Admin password (use strong password in prod)
SUPERSET_DATABASE_URI=postgresql://admin:password@postgres:5432/metastore

# --- Airflow ---
# Apache Airflow orchestration engine
AIRFLOW_HOME=/home/thevinh/repos/tiki-lakehouse-pipeline/airflow_home
AIRFLOW__CORE__DAGS_FOLDER=/home/thevinh/repos/tiki-lakehouse-pipeline/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False             # Disable example DAGs (cleaner UI)
AIRFLOW__CORE__EXECUTOR=SequentialExecutor     # Local executor (use Celery for production)
AIRFLOW__CORE__XCOM_BACKEND=airflow.models.xcom.BaseXCom  # Airflow 2 XCom backend
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8081       # Webserver port
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////home/thevinh/repos/tiki-lakehouse-pipeline/airflow_home/airflow.db

# --- dbt ---
# Data build tool configuration
DBT_TARGET=dev                                 # Target environment (dev, test, prod)
DBT_PROJECT_DIR=/home/thevinh/repos/tiki-lakehouse-pipeline/dbt_tiki

# --- Logging & Debugging ---
DEBUG=0                                        # Enable debug logging (0=off, 1=on)
LOG_LEVEL=INFO                                 # Log level (DEBUG, INFO, WARNING, ERROR)
